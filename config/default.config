import nextflow.util.SysHelper

params {
    //algorithm running environment
    ucla_cds = true

    cache_intermediate_pipeline_steps = false
    keep_input_prefix = false

    //max_number_of_parallel_jobs = 1
    max_cpus   = SysHelper.getAvailCpus()
    max_memory = SysHelper.getAvailMemory()

    min_cpus = 1
    min_memory = 1.MB

    // default docker container registry
    docker_container_registry_uclahscds = "ghcr.io/uclahs-cds"
    docker_container_registry_theboutroslab = "ghcr.io/theboutroslab"

    //algorithm version
    pipeval_version = "5.2.0"
    GATK_version = "4.6.2.0"
    somaticsniper_version = "1.0.5.0"
    bam_readcount_version = "1.0.1"
    strelka2_version = "2.9.10"
    manta_version = "1.6.0"
    MuSE_version = "2.1.2"
    BCFtools_version = "1.23.1"
    call_ssnv_r_version = "dev"
    vcf2maf_version = "v1.6.18"
    bpg_version = "7.1.0"
    src_util_version = "1.3.0"
    deepsomatic_version = "1.10.0"
    docker_image_validate_params = "${-> params.docker_container_registry_uclahscds}/pipeval:${params.pipeval_version}"
    docker_image_GATK = "broadinstitute/gatk:${params.GATK_version}"
    docker_image_somaticsniper = "${-> params.docker_container_registry_uclahscds}/somaticsniper:${params.somaticsniper_version}"
    docker_image_bam_readcount = "ghcr.io/yashpatel6/bam_readcount:${params.bam_readcount_version}"
    docker_image_strelka2 = "${-> params.docker_container_registry_uclahscds}/strelka2:${params.strelka2_version}"
    docker_image_manta = "${-> params.docker_container_registry_uclahscds}/manta:${params.manta_version}"
    docker_image_MuSE = "${-> params.docker_container_registry_uclahscds}/muse:${params.MuSE_version}"
    docker_image_BCFtools = "${-> params.docker_container_registry_theboutroslab}/bcftools:${params.BCFtools_version}"
    docker_image_r_VennDiagram = "${-> params.docker_container_registry_uclahscds}/call-ssnv-r:${params.call_ssnv_r_version}"
    docker_image_vcf2maf = "ghcr.io/mskcc/vcf2maf/vcf2maf:${params.vcf2maf_version}"
    docker_image_bpg = "${-> params.docker_container_registry_uclahscds}/boutroslabplottinggeneral:${params.bpg_version}"
    docker_image_src_util = "ghcr.io/yashpatel6/src-util:${params.src_util_version}"
    docker_image_deepsomatic = "google/deepsomatic:${params.deepsomatic_version}"
}

profiles {
    standard {
        apptainer {
            enabled = false
        }

        docker {
            enabled = true
            uid_and_gid = "-u \$(id -u):\$(id -g)"
            all_group_ids = "\$(for i in `id --real --groups`; do echo -n \"--group-add=\$i \"; done)"
            runOptions = "${uid_and_gid} ${all_group_ids}"
        }

        params.container_mount_flag = "-v"
    }

    // Define copy of default standard profile as docker to allow explicit docker selection
    // Profile aliasing isn't directly available so profile is copied
    docker {
        apptainer {
            enabled = false
        }

        docker {
            enabled = true
            uid_and_gid = "-u \$(id -u):\$(id -g)"
            all_group_ids = "\$(for i in `id --real --groups`; do echo -n \"--group-add=\$i \"; done)"
            runOptions = "${uid_and_gid} ${all_group_ids}"
        }

        params.container_mount_flag = "-v"
    }

    apptainer {
        docker {
            enabled = false
        }

        apptainer {
            enabled = true

            autoMounts = true
            ociAutoPull = true
        }

        params.container_mount_flag = "-B"
    }
}



process {
    executor = 'local'
}
